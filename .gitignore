__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
.claude/

# Virtual environments
venv/
.venv/

# Python package/build outputs
build/
dist/
*.egg-info/

# Original game files never belong in this repo (bring your own, per game)
assets/

# Regenerable artifact families (frame-verify dumps, the emitted lifted
# corpus, and poisoned boot image) are scratch and ignored. Promoted dos_re 3.0
# evidence lives under recovery/: retained Recovery IR, oracle ReplayArtifact,
# and deterministic Atlas sources/indexes. Local artifacts may be explicitly
# promoted during recovery, but none is a normal runtime authority.
artifacts/*
!artifacts/test_oracles/
!artifacts/evidence/
!artifacts/demos/
!artifacts/snapshots/
!artifacts/codemap/
!artifacts/frame_2d1f/

# Scratch traces, dumps, and rendered probes
tmp_*.bin
tmp_*.png
frame.png
*.stackdump

# Runtime save sink (dos_re --save-dir): the game's own SKYROADS.CFG progress
# writes land here when the interactive player runs. Product output, not source
# -- demo/test replay keeps save_dir unset and stays bit-deterministic.
saves/

# Crash snapshots: 1 MB machine images written on a fault (dos_re.crash).
# Local debugging evidence -- resumable, regenerable, and never a source input.
artifacts/crashes/

# The RECOVERED (CPUless) corpus (skyroads/recovered/) is COMMITTED, not
# ignored: the dos_re 2.0 stage-2 no-CPU port surface play_cpuless.py runs.
# scripts/build_recovered.py regenerates it in place (deterministically), so a
# rebuild that changes any byte shows up as a git diff (drift detection).

# Recovered-corpus build intermediates + scratch adapters (regenerated by
# build_recovered.py; the committed record is artifacts/codemap/cpuless_manifest.json)
artifacts/codemap/recovered_census.json
artifacts/codemap/dispatch_evidence_observed.json
artifacts/recovered_adapters/

# Ephemeral play_cpuless session recordings. Every session records one so a
# crash can be reproduced; a clean run deletes it. artifacts/demos is TRACKED,
# so a recording left behind by a failed finalise would otherwise be swept into
# a commit by `git add -A` (it was). Promoting one to a real coverage demo means
# giving it a meaningful name -- which takes it out of this pattern.
artifacts/demos/demo_cpuless_session_*/
artifacts/.corpus-rebuild.lock
