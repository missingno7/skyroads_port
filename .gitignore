__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
.claude/

# Virtual environments
venv/
.venv/

# Python package/build outputs
build/
dist/
*.egg-info/

# Original game files never belong in this repo (bring your own, per game)
assets/

# Regenerable artifact families (snapshots, demos, frame-verify dumps) are
# scratch and ignored. PROMOTED evidence is tracked: a demo/oracle that a test
# or ledger references gets moved into artifacts/test_oracles/ or
# artifacts/evidence/ (see docs/demos_and_snapshots.md "Where evidence lives").
artifacts/*
!artifacts/test_oracles/
!artifacts/evidence/

# Scratch traces, dumps, and rendered probes
tmp_*.bin
tmp_*.png
frame.png
*.stackdump

# Runtime save sink (dos_re --save-dir): the game's own SKYROADS.CFG progress
# writes land here when the interactive player runs. Product output, not source
# -- demo/test replay keeps save_dir unset and stays bit-deterministic.
saves/
